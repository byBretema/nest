{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "vendor": {
    "cm_deps": [
      {
        "name": "glm",
        "version": "1.0.3",
        "sys_first": "FALSE",
        "url": "https://github.com/g-truc/glm/archive/refs/tags/1.0.3.zip"
      }
    ]
  },
  "configurePresets": [
    {
      "name": "base-config",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/obj",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "dev",
      "inherits": "base-config",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CM_ENABLE_ASAN": "OFF",
        "CM_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "dev-strict",
      "inherits": "base-config",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CM_ENABLE_ASAN": "OFF",
        "CM_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "dev-asan",
      "inherits": "base-config",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CM_ENABLE_ASAN": "ON",
        "CM_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "release",
      "inherits": "base-config",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CM_ENABLE_ASAN": "OFF",
        "CM_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "release-strict",
      "inherits": "release",
      "cacheVariables": {
        "CM_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "dev-asan",
      "configurePreset": "dev-asan"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "release-strict",
      "configurePreset": "release-strict"
    }
  ]
}
